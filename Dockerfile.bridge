FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc libhidapi-hidraw0 \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md /app/
COPY src /app/src

RUN pip install --no-cache-dir .

EXPOSE 9123

CMD ["fa860-bridge", "--transport", "hid", "--vendor-id", "0x0483", "--product-id", "0x5750", "--listen-host", "0.0.0.0", "--listen-port", "9123"]